# =============================================================================
# X Careers — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values.
# Never commit .env.local — it's already in .gitignore.
# =============================================================================

# -----------------------------------------------------------------------------
# App URL (used for OAuth callback)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Session encryption — generate with: openssl rand -base64 32
# -----------------------------------------------------------------------------
AUTH_SECRET=

# -----------------------------------------------------------------------------
# xAI / Grok API (https://console.x.ai)
# -----------------------------------------------------------------------------
XAI_API_KEY=

# Optional: model override (default: grok-3-mini)
# XAI_MODEL=grok-3-mini

# -----------------------------------------------------------------------------
# X API v2 — OAuth 2.0 (https://developer.x.com)
# -----------------------------------------------------------------------------
# Create an app at developer.x.com, enable OAuth 2.0 with PKCE.
# Set the callback URL to: ${NEXT_PUBLIC_URL}/api/auth/x/callback
# Required scopes: tweet.read, tweet.write, users.read, offline.access
X_CLIENT_ID=
X_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# X API v2 — OAuth 1.0a (optional, fallback when not signed in via OAuth 2.0)
# -----------------------------------------------------------------------------
# Found under your app's "Keys and tokens" tab in the developer portal.
# X_API_KEY=
# X_API_SECRET=
# X_ACCESS_TOKEN=
# X_ACCESS_TOKEN_SECRET=
